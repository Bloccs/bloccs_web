[node]
id      = "validate"
version = "0.1.0"
kind    = "transform"

[doc]
intent = "Check the order is well-formed before routing."

[ports.in]
order = { schema = "Order@1" }

[ports.out]
valid = { schema = "Order@1" }

[effects]

[contract]
pure_core    = "BloccsWebDev.Nodes.Validate.transform/2"
effect_shell = "BloccsWebDev.Nodes.Validate.execute/2"
